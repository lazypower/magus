[Unit]
Description=Magus: Provision data disk

[Service]
Type=oneshot
ExecStart=/usr/bin/bash -c 'set -euo pipefail; \
  DISK=/dev/disk/by-id/nvme-Samsung_SSD_990_PRO_4TB_S7KGNU0Y708625D; \
  echo "[magus] checking data disk..." >&2; \
  NEEDS_SETUP=0; \
  findmnt -n /var/data -o SOURCE | grep -qx "$$DISK" || NEEDS_SETUP=1; \
  grep -q "$$DISK /var/data xfs" /etc/fstab || NEEDS_SETUP=1; \
  if [ "$$NEEDS_SETUP" -eq 0 ]; then \
    echo "[magus] data disk already converged" >&2; \
    exit 0; \
  fi; \
  echo "[magus] provisioning data disk..." >&2; \
  if ! blkid -s TYPE -o value "$$DISK" | grep -q xfs; then \
    echo "[magus] formatting $$DISK as xfs" >&2; \
    mkfs.xfs -f "$$DISK"; \
  fi; \
  mkdir -p /var/data; \
  grep -q "$$DISK" /etc/fstab || \
    echo "$$DISK /var/data xfs defaults,noatime,nofail 0 0" >> /etc/fstab; \
  echo "[magus] mounting /var/data" >&2; \
  mount -a; \
  mkdir -p /var/data/ollama /var/data/models /var/data/huggingface; \
  echo "[magus] data disk provisioned" >&2'

[Install]
WantedBy=multi-user.target
